APP_NAME="Munoludy"
APP_ENV=local
APP_KEY=base64:rKxB8VTuONFT/ljfx+0x54p15GcRP9LTyunyGRp3hpE=
APP_DEBUG=true
APP_TIMEZONE=Europe/Warsaw
APP_URL=http://muno.local

APP_LOCALE=pl
APP_FALLBACK_LOCALE=pl
APP_FAKER_LOCALE=pl_PL

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
